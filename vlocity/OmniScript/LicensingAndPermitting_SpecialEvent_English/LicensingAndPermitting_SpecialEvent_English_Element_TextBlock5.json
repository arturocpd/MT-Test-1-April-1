        "text": "<div class=\"slds-text-heading_small slds-text-color_success slds-p-top_small slds-p-bottom_small\" style=\"text-align: center;\"><span class=\"ng-binding\" style=\"color: #169179;\">Your application was submitted.</span></div>\n<div class=\"slds-text-heading_small slds-text-color_success slds-p-top_small slds-p-bottom_small\" style=\"text-align: center;\">&nbsp;</div>\n<div class=\"slds-text-heading_small slds-text-color_success slds-p-top_small slds-p-bottom_small\" style=\"text-align: center;\"><span class=\"ng-binding\" style=\"color: #000000;\">Your application ID is %CreatedApplicationId%.</span></div>\n<div class=\"slds-p-bottom_x-small\" style=\"text-align: center;\">\n<p>Amount Paid</p>\n</div>\n<div class=\"slds-text-heading_large slds-p-bottom_medium\" style=\"text-align: center;\">\n<h1><strong><span class=\"ng-binding\">$150.00</span></strong></h1>\n</div>\n<div class=\"slds-p-bottom_medium\">\n<p style=\"text-align: center;\">Use your application ID in any correspondence with us.</p>\n<p style=\"text-align: center;\">The payment details are displayed in the Fee Payment History page.</p>\n</div>",
